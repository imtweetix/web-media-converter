{
  "name": "web-media-converter",
  "private": true,
  "version": "2.10.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "npm run type-check && vite build",
    "build:netlify": "npm ci --legacy-peer-deps && npm run build",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist",
    "build:profile": "vite build --mode production --profile",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf:preview": "npm run build && npm run preview"
  },
  "dependencies": {
    "@awesome.me/kit-c9f4d240a1": "^1.0.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@headlessui/react": "^2.2.9",
    "@sentry/react": "^10.43.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
